# Copy this file to .env.local and fill in values

# Database — start with: docker compose up -d
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vipassana_hub"

# NextAuth — generate a secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<generate-with-openssl-rand-base64-32>"

# Google OAuth (optional — https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
